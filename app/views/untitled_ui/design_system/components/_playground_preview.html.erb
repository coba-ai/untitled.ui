<%# Rendered component preview %>
<div class="min-h-[120px] w-full rounded-lg border border-dashed border-secondary p-8">
  <div class="flex h-full min-h-[56px] items-center justify-center">
    <div class="w-full max-w-md">
      <% if @content.present? %>
        <%= render(@component_class.new(**@props).with_content(@content)) %>
      <% else %>
        <%= render @component_class.new(**@props) %>
      <% end %>
    </div>
  </div>
</div>

<%# Code snippet %>
<div class="mt-4">
  <h3 class="mb-2 text-sm font-semibold uppercase tracking-wider text-quaternary">Code</h3>
  <%= render "untitled_ui/design_system/shared/code_block", code: @code %>
</div>
