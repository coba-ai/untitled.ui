<%= render "untitled_ui/design_system/shared/example_section", title: "Stat Cards" do %>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <%= render(Ui::Stat::Component.new(
      label: "Total Revenue",
      value: "$45,231.89",
      change: "+20.1%",
      period: "vs last month",
      icon: currency_icon
    )) %>
    <%= render(Ui::Stat::Component.new(
      label: "Active Users",
      value: "2,420",
      change: "+12.5%",
      period: "vs last month",
      icon: users_icon
    )) %>
    <%= render(Ui::Stat::Component.new(
      label: "Bounce Rate",
      value: "24.3%",
      change: "-4.2%",
      period: "vs last month",
      icon: chart_icon
    )) %>
  </div>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: 'render(Ui::Stat::Component.new(
  label: "Total Revenue",
  value: "$45,231.89",
  change: "+20.1%",
  period: "vs last month",
  icon: currency_icon_svg
))' %>

