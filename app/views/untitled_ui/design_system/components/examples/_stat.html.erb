<%= render "untitled_ui/design_system/shared/example_section", title: "Explicit Trend Override" do %>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <%= render(Ui::Stat::Component.new(
      label: "Response Time",
      value: "120ms",
      change: "-15%",
      trend: :up,
      period: "faster vs last month"
    )) %>
    <%= render(Ui::Stat::Component.new(
      label: "Error Rate",
      value: "0.5%",
      change: "+0.1%",
      trend: :down,
      period: "vs last month"
    )) %>
  </div>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: '# Override auto-detected trend (e.g., lower response time is good)
render(Ui::Stat::Component.new(
