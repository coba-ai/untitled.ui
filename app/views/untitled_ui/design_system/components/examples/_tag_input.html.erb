<%= render "untitled_ui/design_system/shared/example_section", title: "Default" do %>
  <div class="max-w-sm">
    <%= render Ui::TagInput::Component.new(placeholder: "Add a tag...") %>
  </div>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: 'render Ui::TagInput::Component.new(placeholder: "Add a tag...")' %>

<%= render "untitled_ui/design_system/shared/example_section", title: "With Label & Hint" do %>
  <div class="max-w-sm">
    <%= render Ui::TagInput::Component.new(
      label: "Skills",
      placeholder: "Add a skill...",
      hint: "Press Enter or comma to add a tag. Backspace removes the last tag."
    ) %>
  </div>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: 'render Ui::TagInput::Component.new(label: "Skills", placeholder: "Add a skill...", hint: "Press Enter or comma to add a tag.")' %>

<%= render "untitled_ui/design_system/shared/example_section", title: "With Pre-filled Tags (Array)" do %>
  <div class="max-w-sm">
    <%= render Ui::TagInput::Component.new(
      label: "Technologies",
      value: ["Ruby", "Rails", "JavaScript"],
      placeholder: "Add more..."
    ) %>
  </div>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: 'render Ui::TagInput::Component.new(label: "Technologies", value: ["Ruby", "Rails", "JavaScript"])' %>

<%= render "untitled_ui/design_system/shared/example_section", title: "With Pre-filled Tags (String)" do %>
  <div class="max-w-sm">
    <%= render Ui::TagInput::Component.new(
      label: "Categories",
      name: "post[categories]",
      value: "design,ux,frontend",
      placeholder: "Add category..."
    ) %>
  </div>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: 'render Ui::TagInput::Component.new(label: "Categories", name: "post[categories]", value: "design,ux,frontend")' %>

<%= render "untitled_ui/design_system/shared/example_section", title: "Max Tags Limit" do %>
