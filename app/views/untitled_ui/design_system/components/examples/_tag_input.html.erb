      label: "Top 3 Skills",
      placeholder: "Add up to 3 skills...",
      hint: "You can add at most 3 tags.",
      max_tags: 3
    ) %>
  </div>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: 'render Ui::TagInput::Component.new(label: "Top 3 Skills", hint: "Max 3 tags.", max_tags: 3)' %>

