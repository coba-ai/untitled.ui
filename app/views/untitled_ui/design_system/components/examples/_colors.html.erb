<%# Primary Colors %>
<div class="mb-8 overflow-hidden rounded-xl bg-primary shadow-xs ring-1 ring-secondary">
  <div class="border-b border-secondary px-6 py-4">
    <h2 class="text-lg font-semibold text-primary">Primary Colors</h2>
    <p class="mt-1 text-sm text-tertiary">The four foundation colors of the design system.</p>
  </div>
  <div class="grid grid-cols-2 gap-4 p-6 lg:grid-cols-4">
    <div>
      <div class="h-24 rounded-lg bg-brand-500"></div>
      <p class="mt-2 text-sm font-semibold text-primary">Brand 500</p>
      <p class="text-xs text-tertiary">Primary brand color</p>
    </div>
    <div>
      <div class="h-24 rounded-lg bg-gray-500"></div>
      <p class="mt-2 text-sm font-semibold text-primary">Gray 500</p>
      <p class="text-xs text-tertiary">Neutral midtone</p>
    </div>
    <div>
      <div class="h-24 rounded-lg bg-error-500"></div>
      <p class="mt-2 text-sm font-semibold text-primary">Error 500</p>
      <p class="text-xs text-tertiary">Destructive actions</p>
    </div>
    <div>
      <div class="h-24 rounded-lg bg-success-500"></div>
      <p class="mt-2 text-sm font-semibold text-primary">Success 500</p>
      <p class="text-xs text-tertiary">Positive feedback</p>
    </div>
  </div>
</div>

<%# Brand Scale %>
<div class="mb-8 overflow-hidden rounded-xl bg-primary shadow-xs ring-1 ring-secondary">
  <div class="border-b border-secondary px-6 py-4">
    <h2 class="text-lg font-semibold text-primary">Brand Scale</h2>
    <p class="mt-1 text-sm text-tertiary">Main brand color scale. Use <code class="text-xs font-mono bg-secondary px-1 py-0.5 rounded">brand-*</code> tokens.</p>
  </div>
  <div class="grid grid-cols-4 gap-0 lg:grid-cols-12">
    <% [
      { shade: "25",  bg: "bg-brand-25",  text: "dark" },
      { shade: "50",  bg: "bg-brand-50",  text: "dark" },
      { shade: "100", bg: "bg-brand-100", text: "dark" },
      { shade: "200", bg: "bg-brand-200", text: "dark" },
      { shade: "300", bg: "bg-brand-300", text: "dark" },
      { shade: "400", bg: "bg-brand-400", text: "dark" },
      { shade: "500", bg: "bg-brand-500", text: "light" },
      { shade: "600", bg: "bg-brand-600", text: "light" },
      { shade: "700", bg: "bg-brand-700", text: "light" },
      { shade: "800", bg: "bg-brand-800", text: "light" },
      { shade: "900", bg: "bg-brand-900", text: "light" },
      { shade: "950", bg: "bg-brand-950", text: "light" }
    ].each do |c| %>
      <div class="flex flex-col items-center p-3 <%= c[:bg] %>">
        <span class="text-xs font-semibold <%= c[:text] == 'light' ? 'text-white' : 'text-gray-900' %>"><%= c[:shade] %></span>
      </div>
    <% end %>
  </div>
</div>

