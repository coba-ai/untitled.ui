<%# Semantic Token Mapping %>
<div class="mb-8 overflow-hidden rounded-xl bg-primary shadow-xs ring-1 ring-secondary">
  <div class="border-b border-secondary px-6 py-4">
    <h2 class="text-lg font-semibold text-primary">Semantic Token Mapping</h2>
    <p class="mt-1 text-sm text-tertiary">How primary colors map to Untitled UI semantic tokens.</p>
  </div>
  <table class="w-full text-sm">
    <thead class="bg-secondary">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-semibold text-quaternary">Token</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-quaternary">Maps To</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-quaternary">Color</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-quaternary">Usage</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-secondary">
      <tr>
        <td class="px-6 py-3 font-mono text-xs text-brand-secondary">bg-brand-solid</td>
        <td class="px-6 py-3 font-mono text-xs text-tertiary">brand-600</td>
        <td class="px-6 py-3"><span class="inline-block size-4 rounded bg-brand-solid"></span></td>
        <td class="px-6 py-3 text-tertiary">Primary buttons, CTAs</td>
      </tr>
      <tr>
        <td class="px-6 py-3 font-mono text-xs text-brand-secondary">bg-brand-solid_hover</td>
        <td class="px-6 py-3 font-mono text-xs text-tertiary">brand-700</td>
        <td class="px-6 py-3"><span class="inline-block size-4 rounded bg-brand-solid_hover"></span></td>
        <td class="px-6 py-3 text-tertiary">Hover state for primary buttons</td>
      </tr>
      <tr>
        <td class="px-6 py-3 font-mono text-xs text-brand-secondary">bg-brand-primary_alt</td>
        <td class="px-6 py-3 font-mono text-xs text-tertiary">brand-50</td>
        <td class="px-6 py-3"><span class="inline-block size-4 rounded bg-brand-primary_alt"></span></td>
        <td class="px-6 py-3 text-tertiary">Light tinted backgrounds</td>
      </tr>
      <tr>
        <td class="px-6 py-3 font-mono text-xs text-brand-secondary">text-brand-secondary</td>
        <td class="px-6 py-3 font-mono text-xs text-tertiary">brand-700</td>
        <td class="px-6 py-3"><span class="inline-block size-4 rounded bg-brand-600"></span></td>
        <td class="px-6 py-3 text-tertiary">Brand-colored text</td>
      </tr>
      <tr>
        <td class="px-6 py-3 font-mono text-xs text-brand-secondary">ring-brand</td>
        <td class="px-6 py-3 font-mono text-xs text-tertiary">brand-600</td>
        <td class="px-6 py-3"><span class="inline-block size-4 rounded bg-brand-600"></span></td>
        <td class="px-6 py-3 text-tertiary">Focus rings, borders</td>
      </tr>
    </tbody>
  </table>
</div>

<%# Usage Example %>
<div class="mb-8 overflow-hidden rounded-xl bg-primary shadow-xs ring-1 ring-secondary">
  <div class="border-b border-secondary px-6 py-4">
    <h2 class="text-lg font-semibold text-primary">Usage Examples</h2>
  </div>
  <div class="space-y-4 p-6">
    <div class="flex flex-wrap items-center gap-3">
      <div class="rounded-lg bg-brand-500 px-4 py-2 text-sm font-semibold text-white">bg-brand-500</div>
      <div class="rounded-lg bg-error-500 px-4 py-2 text-sm font-semibold text-white">bg-error-500</div>
      <div class="rounded-lg bg-warning-500 px-4 py-2 text-sm font-semibold text-white">bg-warning-500</div>
      <div class="rounded-lg bg-success-500 px-4 py-2 text-sm font-semibold text-white">bg-success-500</div>
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <div class="rounded-lg bg-brand-100 px-4 py-2 text-sm font-semibold text-brand-800">bg-brand-100</div>
      <div class="rounded-lg bg-error-100 px-4 py-2 text-sm font-semibold text-error-700">bg-error-100</div>
      <div class="rounded-lg bg-warning-100 px-4 py-2 text-sm font-semibold text-warning-700">bg-warning-100</div>
      <div class="rounded-lg bg-success-100 px-4 py-2 text-sm font-semibold text-success-700">bg-success-100</div>
    </div>
  </div>
  <div class="border-t border-secondary bg-secondary/50 px-6 py-4">
    <pre class="text-xs text-tertiary"><code><%# Tailwind classes %>
bg-brand-500            <%# Primary brand color %>
bg-error-500            <%# Error / destructive %>
bg-warning-500          <%# Warning / caution %>
bg-success-500          <%# Success / positive %>

<%# Semantic tokens (from Untitled UI theme) %>
bg-brand-solid          <%# Primary button fill %>
text-brand-secondary    <%# Brand-colored text %>
ring-brand              <%# Focus ring %></code></pre>
  </div>
</div>
