end' %>

<%= render "untitled_ui/design_system/shared/example_section", title: "Left Position" do %>
  <%= render Ui::Drawer::Component.new(id: "ds-drawer-left", position: :left) do |drawer| %>
    <% drawer.with_trigger do %>
      <%= render(Ui::Button::Component.new(color: :secondary)) { "Open Left Drawer" } %>
    <% end %>
    <% drawer.with_header do %>
      <h3 class="text-lg font-semibold text-primary">Left Drawer</h3>
    <% end %>
    <p class="text-sm text-tertiary">This drawer slides in from the left side of the screen.</p>
    <% drawer.with_footer do %>
      <%= render(Ui::Button::Component.new(color: :secondary, data: { action: "click->drawer#close" })) { "Close" } %>
    <% end %>
  <% end %>
<% end %>

