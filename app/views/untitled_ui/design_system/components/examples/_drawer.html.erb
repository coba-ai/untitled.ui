<%= render "untitled_ui/design_system/shared/example_section", title: "Basic Drawer (Right)" do %>
  <%= render Ui::Drawer::Component.new(id: "ds-drawer-basic") do |drawer| %>
    <% drawer.with_trigger do %>
      <%= render(Ui::Button::Component.new) { "Open Drawer" } %>
    <% end %>
    <% drawer.with_header do %>
      <h3 class="text-lg font-semibold text-primary">Drawer Title</h3>
      <p class="text-sm text-tertiary">This is a description of the drawer content.</p>
    <% end %>
    <p class="text-sm text-tertiary">This is the body content of the drawer. You can put any content here including forms, text, or other components.</p>
    <% drawer.with_footer do %>
      <div class="flex justify-end gap-3">
        <%= render(Ui::Button::Component.new(color: :secondary, data: { action: "click->drawer#close" })) { "Cancel" } %>
        <%= render(Ui::Button::Component.new(data: { action: "click->drawer#close" })) { "Confirm" } %>
      </div>
    <% end %>
  <% end %>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: 'render Ui::Drawer::Component.new(id: "my-drawer") do |drawer|
  drawer.with_trigger do
