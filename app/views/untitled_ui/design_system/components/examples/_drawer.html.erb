<%= render "untitled_ui/design_system/shared/example_section", title: "Size Variants" do %>
  <div class="flex flex-wrap gap-3">
    <%= render Ui::Drawer::Component.new(id: "ds-drawer-sm", size: :sm) do |drawer| %>
      <% drawer.with_trigger do %>
        <%= render(Ui::Button::Component.new(color: :secondary, size: :sm)) { "Small (w-80)" } %>
      <% end %>
      <% drawer.with_header do %>
        <h3 class="text-lg font-semibold text-primary">Small Drawer</h3>
      <% end %>
      <p class="text-sm text-tertiary">This is the small size drawer (w-80).</p>
    <% end %>

    <%= render Ui::Drawer::Component.new(id: "ds-drawer-md", size: :md) do |drawer| %>
      <% drawer.with_trigger do %>
        <%= render(Ui::Button::Component.new(color: :secondary, size: :sm)) { "Medium (w-96)" } %>
      <% end %>
      <% drawer.with_header do %>
        <h3 class="text-lg font-semibold text-primary">Medium Drawer</h3>
      <% end %>
      <p class="text-sm text-tertiary">This is the medium size drawer (w-96). This is the default size.</p>
    <% end %>

    <%= render Ui::Drawer::Component.new(id: "ds-drawer-lg", size: :lg) do |drawer| %>
      <% drawer.with_trigger do %>
        <%= render(Ui::Button::Component.new(color: :secondary, size: :sm)) { "Large (w-[32rem])" } %>
      <% end %>
      <% drawer.with_header do %>
        <h3 class="text-lg font-semibold text-primary">Large Drawer</h3>
      <% end %>
      <p class="text-sm text-tertiary">This is the large size drawer (w-[32rem]).</p>
    <% end %>
  </div>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: '# Size variants: :sm (w-80), :md (w-96, default), :lg (w-[32rem])
render Ui::Drawer::Component.new(size: :lg) do |drawer|
