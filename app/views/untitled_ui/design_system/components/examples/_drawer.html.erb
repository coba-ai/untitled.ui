end' %>

<%= render "untitled_ui/design_system/shared/example_section", title: "Without Footer" do %>
  <%= render Ui::Drawer::Component.new(id: "ds-drawer-no-footer") do |drawer| %>
    <% drawer.with_trigger do %>
      <%= render(Ui::Button::Component.new(color: :secondary)) { "Open (No Footer)" } %>
    <% end %>
    <% drawer.with_header do %>
      <h3 class="text-lg font-semibold text-primary">Information</h3>
    <% end %>
    <p class="text-sm text-tertiary">This drawer has no footer. Use the close button in the header to dismiss.</p>
  <% end %>
<% end %>

<%= render "untitled_ui/design_system/shared/code_block", code: '# Omit drawer.with_footer to render without footer' %>
