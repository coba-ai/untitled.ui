<!DOCTYPE html>
<html class="h-full">
  <head>
    <title>Design System - Untitled UI</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags "untitled_ui" %>
  </head>
  <body class="min-h-full bg-secondary text-primary <%= untitled_ui_theme_class %>">
    <div class="flex min-h-dvh">
      <%# Sidebar %>
      <aside class="sticky top-0 h-dvh w-72 shrink-0 overflow-y-auto border-r border-secondary bg-primary px-6 pt-8 pb-8">
        <div class="mb-8 flex items-center justify-between">
          <div>
            <%= link_to untitled_ui.components_path, class: "flex items-center gap-2 text-lg font-bold text-primary" do %>
              <svg class="size-6 text-brand-solid" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z" />
              </svg>
              Untitled UI
            <% end %>
            <p class="mt-1 text-sm text-tertiary">Component Library</p>
          </div>
        </div>

        <%# Theme Switcher %>
        <div class="mb-6">
          <label for="ds-theme-switcher" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-quaternary">Theme</label>
          <div class="flex items-center gap-2">
            <select
              id="ds-theme-switcher"
              class="flex-1 rounded-lg border-0 bg-secondary px-3 py-2 pr-8 text-sm text-primary ring-1 ring-primary ring-inset outline-hidden focus:ring-2 focus:ring-brand"
            >
              <% untitled_ui_available_themes.each do |theme| %>
                <option value="<%= theme[:value] %>"
                        data-has-dark="<%= theme[:has_dark] %>"
                        <%= "selected" if theme[:value] == untitled_ui_theme_class %>><%= theme[:name] %></option>
              <% end %>
            </select>
            <button
              id="ds-dark-toggle"
              type="button"
              title="Toggle dark mode"
              class="hidden rounded-lg p-2 text-tertiary ring-1 ring-primary ring-inset transition hover:bg-primary_hover hover:text-secondary_hover"
            >
              <svg id="ds-dark-icon-sun" class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
              </svg>
              <svg id="ds-dark-icon-moon" class="hidden size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
              </svg>
            </button>
          </div>
        </div>

        <%# Search %>
        <div class="mb-8">
          <div class="relative">
            <svg class="pointer-events-none absolute top-1/2 left-3.5 size-4 -translate-y-1/2 text-fg-quaternary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
            <input type="search" id="ds-component-search" placeholder="Search components..." autocomplete="off" class="w-full rounded-lg border-0 bg-secondary py-2.5 pl-10 pr-3 text-sm text-primary ring-1 ring-primary ring-inset placeholder:text-placeholder focus:ring-2 focus:ring-brand outline-hidden" />
          </div>
        </div>

        <%# Nav %>
        <nav id="ds-component-nav" class="space-y-6 pb-8">
          <% UntitledUi::DesignSystem::ComponentsController::COMPONENTS.group_by { |c| c[:category] }.each do |category, components| %>
            <div data-nav-group>
              <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-quaternary"><%= category %></h3>
              <ul class="space-y-1">
                <% components.sort_by { |c| c[:name] }.each do |comp| %>
                  <li data-nav-item data-name="<%= comp[:name].downcase %>">
                    <%= link_to comp[:name],
                      untitled_ui.component_path(comp[:id]),
                      class: "block rounded-md px-3.5 py-2 text-sm font-medium transition #{comp[:id] == params[:id] ? 'bg-brand-primary_alt text-brand-secondary' : 'text-secondary hover:bg-primary_hover hover:text-secondary_hover'}" %>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </nav>
      </aside>

      <%# Main content %>
      <main class="flex-1 px-8 pt-8 pb-10 lg:px-12 lg:pb-12">
        <%= yield %>
      </main>
    </div>

    <script>
      (function() {
        // Theme switcher + dark mode toggle
        var switcher = document.getElementById('ds-theme-switcher');
        var darkToggle = document.getElementById('ds-dark-toggle');
        var sunIcon = document.getElementById('ds-dark-icon-sun');
        var moonIcon = document.getElementById('ds-dark-icon-moon');
        var body = document.body;
        var isDark = false;

        function getSelectedOption() {
          return switcher.options[switcher.selectedIndex];
        }

        function hasDarkVariant() {
          return getSelectedOption().getAttribute('data-has-dark') === 'true';
        }

        function getDarkClass(baseTheme) {
          if (!baseTheme) return 'dark-theme';
          var baseName = baseTheme.replace('-theme', '');
          return 'dark_' + baseName + '-theme';
        }

        function applyTheme() {
          body.className = body.className.replace(/\S+-theme/g, '').trim().replace(/\s+/g, ' ');
          var baseTheme = switcher.value;

          if (isDark && hasDarkVariant()) {
            body.classList.add(getDarkClass(baseTheme));
          } else if (baseTheme) {
            body.classList.add(baseTheme);
          }

          localStorage.setItem('untitled-ui-ds-theme', baseTheme);
          localStorage.setItem('untitled-ui-ds-dark', isDark ? '1' : '0');
          updateDarkToggle();
        }

        function updateDarkToggle() {
          if (hasDarkVariant()) {
            darkToggle.classList.remove('hidden');
            sunIcon.classList.toggle('hidden', isDark);
            moonIcon.classList.toggle('hidden', !isDark);
          } else {
            darkToggle.classList.add('hidden');
          }
        }

        // Restore from localStorage
        var savedTheme = localStorage.getItem('untitled-ui-ds-theme');
        var savedDark = localStorage.getItem('untitled-ui-ds-dark');
        if (savedTheme !== null) {
          switcher.value = savedTheme;
        }
        isDark = savedDark === '1';
        applyTheme();

        switcher.addEventListener('change', function() {
          isDark = false;
          applyTheme();
        });

        darkToggle.addEventListener('click', function() {
          isDark = !isDark;
          applyTheme();
        });

        // Component search
        var input = document.getElementById('ds-component-search');
        var items = document.querySelectorAll('[data-nav-item]');
        var groups = document.querySelectorAll('[data-nav-group]');

        input.addEventListener('input', function() {
          var query = this.value.toLowerCase().trim();

          items.forEach(function(item) {
            var name = item.getAttribute('data-name');
            item.style.display = name.includes(query) ? '' : 'none';
          });

          groups.forEach(function(group) {
            var visibleItems = group.querySelectorAll('[data-nav-item]:not([style*="display: none"])');
            group.style.display = visibleItems.length > 0 ? '' : 'none';
          });
        });
      })();
    </script>
  </body>
</html>
