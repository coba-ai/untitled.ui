<div data-controller="command-palette"
     data-command-palette-items-value="<%= items_as_json %>"
     data-command-palette-palette-id-value="<%= palette_id %>">

  <dialog id="<%= palette_id %>"
          class="<%= overlay_classes %>"
          data-command-palette-target="dialog"
          data-action="click->command-palette#closeOnBackdrop">
    <div class="<%= dialog_classes %>">
      <%# Search input %>
      <div class="flex items-center gap-3 border-b border-secondary px-4 py-3">
        <svg class="size-5 shrink-0 text-fg-quaternary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.197 5.197a7.5 7.5 0 0 0 10.606 10.606Z" />
        </svg>
        <input type="text"
               class="flex-1 bg-transparent text-sm text-primary placeholder:text-placeholder focus:outline-none"
               placeholder="<%= placeholder %>"
               autocomplete="off"
               spellcheck="false"
               data-command-palette-target="input"
               data-action="input->command-palette#filter keydown->command-palette#handleKeydown"
               aria-label="<%= placeholder %>"
               aria-controls="<%= palette_id %>-listbox"
               aria-autocomplete="list"
               role="combobox"
               aria-expanded="true">
        <kbd class="hidden sm:flex items-center gap-1 rounded px-1.5 py-0.5 text-xs font-medium text-quaternary ring-1 ring-secondary_alt">
          Esc
        </kbd>
      </div>

      <%# Results list %>
      <div id="<%= palette_id %>-listbox"
           class="max-h-80 overflow-y-auto py-2 select-none"
           role="listbox"
           data-command-palette-target="list">
        <%# Groups are rendered client-side by Stimulus for live filtering %>
        <% grouped_items.each do |group, group_items| %>
          <div class="mb-1" data-command-palette-group data-group-name="<%= group %>">
            <% if group.present? %>
              <div class="px-3 py-1.5 text-xs font-semibold text-quaternary uppercase tracking-wider"
                   data-command-palette-target="groupHeader">
                <%= group %>
              </div>
            <% end %>
            <% group_items.each_with_index do |item, index| %>
              <div class="group mx-1 flex cursor-pointer items-center gap-3 rounded-lg px-3 py-2.5 text-sm outline-hidden transition duration-100 ease-linear hover:bg-primary_hover data-[active]:bg-primary_hover"
                   role="option"
                   tabindex="-1"
                   data-command-palette-target="item"
                   data-value="<%= item[:value] || item['value'] %>"
                   data-label="<%= item[:label] || item['label'] %>"
                   data-group="<%= item[:group] || item['group'] %>"
                   data-action="click->command-palette#selectItem mouseenter->command-palette#setActive"
                   aria-selected="false">
                <% icon = item[:icon] || item['icon'] %>
                <% if icon.present? %>
                  <span class="size-4 shrink-0 text-fg-quaternary group-data-[active]:text-fg-secondary" aria-hidden="true">
                    <%= icon.html_safe %>
                  </span>
                <% end %>
                <span class="flex-1 truncate text-secondary group-data-[active]:text-primary"
                      data-command-palette-target="itemLabel">
                  <%= item[:label] || item['label'] %>
                </span>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Empty state %>
        <div class="hidden px-3 py-8 text-center text-sm text-quaternary"
             data-command-palette-target="emptyState">
          No results found.
        </div>
      </div>

      <%# Footer hint %>
      <div class="flex items-center justify-between border-t border-secondary px-4 py-2.5">
        <div class="flex items-center gap-4 text-xs text-quaternary">
          <span class="flex items-center gap-1.5">
            <kbd class="rounded px-1 py-0.5 ring-1 ring-secondary_alt text-xs font-medium">↑↓</kbd>
            Navigate
          </span>
          <span class="flex items-center gap-1.5">
            <kbd class="rounded px-1 py-0.5 ring-1 ring-secondary_alt text-xs font-medium">↵</kbd>
            Select
          </span>
          <span class="flex items-center gap-1.5">
            <kbd class="rounded px-1 py-0.5 ring-1 ring-secondary_alt text-xs font-medium">Esc</kbd>
            Close
          </span>
        </div>
        <div class="text-xs text-quaternary">
          <span class="hidden sm:inline">⌘K to open</span>
        </div>
      </div>
    </div>
  </dialog>
</div>
