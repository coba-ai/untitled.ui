<div data-controller="stepper"
     data-stepper-current-step-value="<%= current_step %>"
     data-stepper-total-steps-value="<%= steps.size %>"
     class="<%= root_classes %>">

  <%# Step indicators %>
  <nav aria-label="Progress" class="flex w-full items-start">
    <% steps.each_with_index do |step, index| %>
      <%# Steps are 1-based; index is 0-based %>
      <% one_based = index + 1 %>
      <% state = step_state(one_based) %>

      <div class="flex flex-1 flex-col items-center text-center">
        <%# Icon row with connectors %>
        <div class="flex w-full items-center">
          <%# Left connector (hidden for first step) %>
          <% if index > 0 %>
            <div class="<%= connector_classes(step_state(index) == :completed ? :completed : :upcoming) %>"></div>
          <% else %>
            <div class="h-0.5 w-full"></div>
          <% end %>

          <%# Step icon button %>
          <button type="button"
                  <%= "aria-current=\"step\"".html_safe if state == :current %>
                  data-stepper-target="stepButton"
                  data-action="click->stepper#goToStep"
                  data-step-index="<%= one_based %>"
                  class="<%= icon_outer_classes(state) %> cursor-pointer focus:outline-none">
            <% if state == :completed %>
              <span class="<%= icon_inner_classes(state) %>"><%= checkmark_svg.html_safe %></span>
            <% else %>
              <span class="<%= dot_classes(state) %>"></span>
            <% end %>
          </button>

          <%# Right connector (hidden for last step) %>
          <% if index < steps.size - 1 %>
            <div class="<%= connector_classes(state == :completed ? :completed : :upcoming) %>"></div>
          <% else %>
            <div class="h-0.5 w-full"></div>
          <% end %>
        </div>

        <%# Labels %>
        <div class="mt-3 px-1">
          <p class="<%= title_classes(state) %>"><%= step.title %></p>
          <% if step.description.present? %>
            <p class="<%= description_classes(state) %>"><%= step.description %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </nav>

  <%# Step content panels %>
  <div class="mt-6">
    <% panels.each_with_index do |panel, i| %>
      <% one_based = i + 1 %>
      <div role="region"
           aria-label="<%= steps[i]&.title %>"
           data-stepper-target="panel"
           class="<%= one_based != current_step ? 'hidden' : '' %>">
        <%= panel %>
      </div>
    <% end %>
  </div>

  <%# Navigation buttons %>
  <div class="mt-6 flex items-center justify-between gap-3">
    <button type="button"
            data-action="click->stepper#prev"
            data-stepper-target="prevButton"
            class="<%= cx('inline-flex items-center gap-2 rounded-lg border border-secondary bg-primary px-4 py-2.5 text-sm font-semibold text-secondary shadow-xs transition hover:bg-primary_hover focus:outline-none', current_step <= 1 && 'invisible') %>">
      <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
      </svg>
      Back
    </button>

    <span class="text-sm text-tertiary" data-stepper-target="stepCounter">
      Step <%= current_step %> of <%= steps.size %>
    </span>

    <% if current_step < steps.size %>
      <button type="button"
              data-action="click->stepper#next"
              data-stepper-target="nextButton"
              class="inline-flex items-center gap-2 rounded-lg bg-brand-solid px-4 py-2.5 text-sm font-semibold text-white shadow-xs transition hover:bg-brand-solid_hover focus:outline-none">
        Continue
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
      </button>
    <% else %>
      <button type="button"
              data-stepper-target="finishButton"
              class="inline-flex items-center gap-2 rounded-lg bg-success-solid px-4 py-2.5 text-sm font-semibold text-white shadow-xs transition hover:opacity-90 focus:outline-none">
        Finish
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
        </svg>
      </button>
    <% end %>
  </div>
</div>
