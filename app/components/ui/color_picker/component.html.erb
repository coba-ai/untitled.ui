<div
  class="<%= cx('relative flex h-max w-full flex-col items-start justify-start gap-1.5', extra_classes) %>"
  data-controller="<%= disabled ? '' : 'color-picker' %>"
  data-color-picker-value-value="<%= normalized_value %>"
>
  <% if label.present? %>
    <%= render Ui::Label::Component.new(text: label, required: required, for_id: id) %>
  <% end %>

  <%# Trigger button %>
  <div
    class="<%= wrapper_classes %>"
    <% unless disabled %>
      data-action="click->color-picker#toggle"
      data-color-picker-target="trigger"
    <% end %>
  >
    <%# Color swatch preview %>
    <span
      class="ml-3 inline-block size-5 shrink-0 rounded border border-primary"
      style="background-color: <%= normalized_value %>;"
      data-color-picker-target="swatch"
      aria-hidden="true"
    ></span>

    <%# Display value %>
    <input
      type="text"
      readonly
      value="<%= normalized_value %>"
      class="<%= trigger_classes %>"
      <% if id.present? %>id="<%= id %>"<% end %>
      <% if disabled %>disabled<% end %>
      data-color-picker-target="display"
      aria-haspopup="true"
      aria-expanded="false"
    >

    <%# Chevron icon %>
    <svg class="mr-3 size-4 shrink-0 text-fg-quaternary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
    </svg>
  </div>

  <%# Hidden input for form submission %>
  <input
    type="hidden"
    value="<%= normalized_value %>"
    <% if name.present? %>name="<%= name %>"<% end %>
    <% if required %>required<% end %>
    data-color-picker-target="hidden"
  >

  <%# Dropdown panel %>
  <div
    class="absolute top-full z-50 mt-1 hidden w-64 rounded-lg border border-primary bg-primary p-4 shadow-lg"
    data-color-picker-target="panel"
  >
    <%# Swatches grid %>
    <% if swatches.present? %>
      <div class="mb-3 grid grid-cols-6 gap-2">
        <% swatches.each do |swatch_color| %>
          <button
            type="button"
            class="size-8 rounded border-2 border-transparent transition-all hover:scale-110 focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-1"
            style="background-color: <%= swatch_color %>;"
            data-action="click->color-picker#selectSwatch"
            data-color="<%= swatch_color %>"
            aria-label="Select color <%= swatch_color %>"
            data-color-picker-target="swatchButton"
          ></button>
        <% end %>
      </div>
      <div class="mb-3 border-t border-primary"></div>
    <% end %>

    <%# Hex input %>
    <div class="flex flex-col gap-1.5">
      <label class="text-xs font-medium text-secondary">Hex color</label>
      <div class="relative flex w-full flex-row place-content-center place-items-center rounded-lg bg-primary shadow-xs ring-1 ring-primary transition-shadow duration-100 ease-linear ring-inset focus-within:ring-2 focus-within:ring-brand">
        <span class="ml-3 text-sm font-medium text-tertiary">#</span>
        <input
          type="text"
          maxlength="7"
          placeholder="000000"
          class="m-0 w-full bg-transparent px-1.5 py-2 text-md text-primary ring-0 outline-hidden placeholder:text-placeholder"
          data-color-picker-target="hexInput"
          data-action="input->color-picker#onHexInput keydown->color-picker#onHexKeydown"
          aria-label="Hex color value"
        >
        <span
          class="mr-3 inline-block size-5 shrink-0 rounded border border-primary"
          style="background-color: <%= normalized_value %>;"
          data-color-picker-target="hexSwatch"
          aria-hidden="true"
        ></span>
      </div>
    </div>
  </div>

  <% if hint.present? %>
    <%= render Ui::HintText::Component.new(invalid: invalid).with_content(hint) %>
  <% end %>
</div>
