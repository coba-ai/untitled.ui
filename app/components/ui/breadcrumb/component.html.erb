<nav aria-label="Breadcrumb" class="<%= root_classes %>">
  <ol class="flex items-center gap-2">
    <% items.each_with_index do |item, index| %>
      <li class="flex items-center gap-2">
        <%# Separator between items %>
        <% if index > 0 %>
          <span aria-hidden="true"><%= separator_html.html_safe %></span>
        <% end %>

        <% if item.current? %>
          <span class="<%= item_classes(item) %>" aria-current="page">
            <% if item.icon.present? %>
              <span class="flex items-center gap-1.5">
                <%= item.icon.html_safe %>
                <%= item.label %>
              </span>
            <% else %>
              <%= item.label %>
            <% end %>
          </span>
        <% else %>
          <a href="<%= item.href %>" class="<%= link_classes %>">
            <% if item.icon.present? %>
              <%= item.icon.html_safe %>
            <% end %>
            <%= item.label %>
          </a>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
