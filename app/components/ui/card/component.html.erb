<div class="<%= container_classes %>">
  <% if media.present? %>
    <div class="card-media">
      <%= media %>
    </div>
  <% end %>

  <% if header.present? %>
    <div class="<%= header_classes %>">
      <%= header %>
    </div>
  <% end %>

  <div class="<%= body_classes %>">
    <%= content %>
  </div>

  <% if footer.present? %>
    <div class="<%= footer_classes %>">
      <%= footer %>
    </div>
  <% end %>
</div>
