<ol class="<%= root_classes %>">
  <% prepared_items.each do |item| %>
    <li class="relative flex gap-4 pb-8 last:pb-0">
      <%# Connector line and indicator column %>
      <div class="relative flex flex-col items-center">
        <%# Dot or icon indicator %>
        <% if item.icon.present? %>
          <span class="<%= item.icon_wrapper_classes %>">
            <span class="<%= item.icon_classes %>"><%= item.icon.html_safe %></span>
          </span>
        <% else %>
          <div class="flex size-8 shrink-0 items-center justify-center">
            <span class="<%= item.dot_classes %>"></span>
          </div>
        <% end %>

        <%# Vertical connector line (hidden for last item) %>
        <% unless item.last %>
          <div class="mt-1 w-px flex-1 bg-border-secondary"></div>
        <% end %>
      </div>

      <%# Content column %>
      <div class="min-w-0 flex-1 pb-1">
        <div class="flex items-center justify-between gap-x-4">
          <p class="text-sm font-semibold text-primary"><%= item.title %></p>
          <% if item.timestamp.present? %>
            <time class="shrink-0 text-sm text-tertiary"><%= item.timestamp %></time>
          <% end %>
        </div>
        <% if item.description.present? %>
          <p class="mt-1 text-sm text-secondary"><%= item.description %></p>
        <% end %>
      </div>
    </li>
  <% end %>
</ol>
