<%
  col_index_offset = selectable ? 1 : 0
%>
<% if header_content.present? %>
  <div class="overflow-hidden rounded-xl bg-primary shadow-xs ring-1 ring-secondary" <%= stimulus_controller_attrs.map { |k, v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
    <%= header_content %>
    <% if bulk_actions.present? %>
      <div class="hidden px-6 py-3 bg-brand-secondary border-b border-secondary" data-table-target="bulkActions">
        <%= bulk_actions %>
      </div>
    <% end %>
    <div class="overflow-x-auto">
      <table class="<%= cx('w-full', extra_classes) %>">
        <thead class="<%= cx('relative bg-secondary', header_height) %>">
          <tr>
            <% if selectable %>
              <th class="relative p-0 pl-6 pr-3 py-2 outline-hidden text-left w-10">
                <input
                  type="checkbox"
                  class="size-4 rounded border-primary text-brand-solid focus:ring-brand-solid cursor-pointer"
                  data-table-target="selectAll"
                  data-action="change->table#toggleSelectAll"
                  aria-label="Select all rows"
                />
              </th>
            <% end %>
            <% columns.each_with_index do |col, idx| %>
              <th class="relative p-0 px-6 py-2 outline-hidden text-left">
                <div class="flex items-center gap-1">
                  <% if col.sortable %>
                    <button
                      type="button"
                      class="flex items-center gap-1 group focus:outline-none"
                      data-action="click->table#sort"
                      data-table-target="sortButton"
                      data-column="<%= idx + col_index_offset %>"
                      aria-sort="none"
                    >
                      <span class="text-xs font-semibold whitespace-nowrap text-quaternary group-hover:text-secondary"><%= col.label %></span>
                      <span class="relative size-3 text-fg-quaternary shrink-0">
                        <%# Default (unsorted) icon %>
                        <svg data-sort-default class="size-3 text-fg-quaternary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9"/>
                        </svg>
                        <%# Ascending icon %>
                        <svg data-sort-asc class="hidden size-3 text-brand-solid" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 5.25L15.75 9m-7.5 0L12 5.25"/>
                        </svg>
                        <%# Descending icon %>
                        <svg data-sort-desc class="hidden size-3 text-brand-solid" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75L8.25 15m7.5 0L12 18.75"/>
                        </svg>
                      </span>
                    </button>
                  <% else %>
                    <span class="text-xs font-semibold whitespace-nowrap text-quaternary"><%= col.label %></span>
                  <% end %>
                </div>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <%= content %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="overflow-x-auto" <%= stimulus_controller_attrs.map { |k, v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
    <% if bulk_actions.present? %>
      <div class="hidden px-6 py-3 bg-brand-secondary border-b border-secondary" data-table-target="bulkActions">
        <%= bulk_actions %>
      </div>
    <% end %>
    <table class="<%= cx('w-full', extra_classes) %>">
      <thead class="<%= cx('relative bg-secondary', header_height) %>">
        <tr>
          <% if selectable %>
            <th class="relative p-0 pl-6 pr-3 py-2 outline-hidden text-left w-10">
              <input
                type="checkbox"
                class="size-4 rounded border-primary text-brand-solid focus:ring-brand-solid cursor-pointer"
                data-table-target="selectAll"
                data-action="change->table#toggleSelectAll"
                aria-label="Select all rows"
              />
            </th>
          <% end %>
          <% columns.each_with_index do |col, idx| %>
            <th class="relative p-0 px-6 py-2 outline-hidden text-left">
              <div class="flex items-center gap-1">
                <% if col.sortable %>
                  <button
                    type="button"
                    class="flex items-center gap-1 group focus:outline-none"
                    data-action="click->table#sort"
                    data-table-target="sortButton"
                    data-column="<%= idx + col_index_offset %>"
                    aria-sort="none"
                  >
                    <span class="text-xs font-semibold whitespace-nowrap text-quaternary group-hover:text-secondary"><%= col.label %></span>
                    <span class="relative size-3 text-fg-quaternary shrink-0">
                      <%# Default (unsorted) icon %>
                      <svg data-sort-default class="size-3 text-fg-quaternary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9"/>
                      </svg>
                      <%# Ascending icon %>
                      <svg data-sort-asc class="hidden size-3 text-brand-solid" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 5.25L15.75 9m-7.5 0L12 5.25"/>
                      </svg>
                      <%# Descending icon %>
                      <svg data-sort-desc class="hidden size-3 text-brand-solid" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75L8.25 15m7.5 0L12 18.75"/>
                      </svg>
                    </span>
                  </button>
                <% else %>
                  <span class="text-xs font-semibold whitespace-nowrap text-quaternary"><%= col.label %></span>
                <% end %>
              </div>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <%= content %>
      </tbody>
    </table>
  </div>
<% end %>
