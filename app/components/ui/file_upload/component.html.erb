<div
  class="<%= cx('flex h-max w-full flex-col items-start justify-start gap-1.5', extra_classes) %>"
  data-controller="file-upload"
  <% if max_size.present? %>data-file-upload-max-size-value="<%= max_size %>"<% end %>
>
  <% if label.present? %>
    <%= render Ui::Label::Component.new(text: label, for_id: input_id) %>
  <% end %>

  <div
    class="<%= zone_classes %>"
    data-file-upload-target="zone"
    data-action="click->file-upload#openDialog dragenter->file-upload#dragEnter dragover->file-upload#dragOver dragleave->file-upload#dragLeave drop->file-upload#drop"
  >
    <%# Upload cloud icon %>
    <div class="mb-3 flex items-center justify-center rounded-lg border border-secondary p-2.5 shadow-xs">
      <svg class="size-5 text-fg-quaternary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
      </svg>
    </div>

    <%# Call to action text %>
    <p class="text-sm text-tertiary" data-file-upload-target="text">
      <span class="font-semibold text-brand-secondary">Click to upload</span>
      or drag and drop
    </p>

    <%# File name display (hidden by default) %>
    <p class="hidden text-sm font-medium text-primary" data-file-upload-target="filename"></p>

    <% if hint.present? && !invalid %>
      <p class="mt-1 text-xs text-tertiary"><%= hint %></p>
    <% end %>

    <%# Hidden file input %>
    <input
      type="file"
      class="hidden"
      data-file-upload-target="input"
      data-action="change->file-upload#fileSelected"
      <% if input_id.present? %>id="<%= input_id %>"<% end %>
      <% if name.present? %>name="<%= name %>"<% end %>
      <% if accept.present? %>accept="<%= accept %>"<% end %>
      <% if multiple %>multiple<% end %>
      <% if disabled %>disabled<% end %>
    >
  </div>

  <% if invalid && hint.present? %>
    <%= render Ui::HintText::Component.new(invalid: true).with_content(hint) %>
  <% end %>
</div>
